# --- Wingman OPEN-SOURCE track config: Ollama for BOTH llm + embeddings ($0) ---
# 1) ollama serve   2) ollama pull qwen2.5:3b   3) ollama pull nomic-embed-text
LLM_PROVIDER="ollama"
LLM_MODEL="qwen2.5:3b"
LLM_ENDPOINT="http://localhost:11434/v1"
LLM_API_KEY="ollama"          # placeholder; Ollama ignores it

# Embeddings REQUIRED or cognee silently falls back to (paid) OpenAI.
# Note: embed endpoint differs from the LLM one (/api/embed vs /v1).
EMBEDDING_PROVIDER="ollama"
EMBEDDING_MODEL="nomic-embed-text"
EMBEDDING_ENDPOINT="http://localhost:11434/api/embed"
EMBEDDING_DIMENSIONS=768

# Tokenizer for token-counting with the Ollama embedder (small, ungated).
HUGGINGFACE_TOKENIZER="bert-base-uncased"

# Local models can be slow to cold-start; skip the 30s preflight and keep the model warm.
COGNEE_SKIP_CONNECTION_TEST="true"

# Constrained structured output so small local models fill the schema instead of echoing it.
LLM_INSTRUCTOR_MODE="json_schema_mode"

# Disable session memory so repeat queries do not degrade to "Got it.".
CACHING="false"
